# Copy to .env and fill in. Never commit .env.

# Groq (Llama 3.3 70B) — used by scorer, critic, improver, email classifier
GROQ_API_KEY=

# Telegram bot — alerts for real recruiter responses & calendar reminders
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard cookie-session login
DASHBOARD_PASSWORD=
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth (Gmail + Calendar share one credential)
# Run OAuth flow on Mac, then copy token.json to ./data/
GOOGLE_CREDENTIALS_PATH=/app/data/credentials.json
GOOGLE_TOKEN_PATH=/app/data/token.json

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata
SCRAPE_HOUR=6
SCRAPE_MINUTE=0

# Data source — CSV path the scheduler reads at 6am IST
JOBS_CSV_PATH=/app/dummy_jobs.csv

# SQLite path (shared between backend + gmail-watcher containers via volume)
DATABASE_URL=sqlite:////app/data/jobs.db

# Webhook secret — protects POST /webhook/jobs from unauthorized job injection
# If set, callers must send: Authorization: Bearer <value>
# Leave empty to disable auth (not recommended in production)
WEBHOOK_SECRET=
